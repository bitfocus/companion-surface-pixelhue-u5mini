{
	"name": "companion-surface-pixelhue-u5mini",
	"version": "1.0.3",
	"description": "Pixelhue U5 Mini surface module for Companion 4.3",
	"main": "dist/main.js",
	"type": "module",
	"scripts": {
		"format": "prettier -w .",
		"package": "yarn build && companion-surface-build",
		"build": "rimraf dist && tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch",
		"lint:raw": "eslint",
		"lint": "eslint ."
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/companion.git"
	},
	"engines": {
		"node": "^22.18",
		"yarn": "^4"
	},
	"dependencies": {
		"@companion-surface/base": "~1.1.3",
		"@pixelhue/event-controller-sdk": "^1.0.0",
		"pngjs": "^7.0.0"
	},
	"devDependencies": {
		"@companion-module/tools": "^3.0.0",
		"@types/node": "^22.19.15",
		"@types/pngjs": "^6.0.5",
		"eslint": "^9.39.4",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.57.1"
	},
	"prettier": "@companion-module/tools/.prettierrc.json",
	"lint-staged": {
		"*.{css,json,md,scss}": [
			"prettier --write"
		],
		"*.{ts,tsx,js,jsx}": [
			"yarn lint:raw --fix"
		]
	},
	"packageManager": "yarn@4.13.0"
}
